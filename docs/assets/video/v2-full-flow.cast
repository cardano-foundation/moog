[211.422301,"o","\u001b[0;90m# Show apply, requester retract, Phase-3 reject, and fresh-reject refusal.\u001b[0m\r\n"]
[218.422301,"o","\u001b[H\u001b[2J\u001b[3J\u001b[1;36mPart 4: apply terminal outcome\u001b[0m\r\n\r\n"]
[218.422429,"o","\u001b[0;90m# Apply was shown in Part 3 for each request type.\u001b[0m\r\n\u001b[0;90m# A processable request is consumed by oracle token update.\u001b[0m\r\n\u001b[1;32m$ moog oracle token update -o <request-ref>\u001b[0m\r\n"]
[218.422491,"o","\u001b[1;33mapply outcome already demonstrated by the four populated fact tables\u001b[0m\r\n"]
[225.422491,"o","\u001b[H\u001b[2J\u001b[3J"]
[225.422606,"o","\u001b[1;36mPart 4: submit a request for retract\u001b[0m\r\n\r\n\u001b[0;90m# Submit a config request and keep it pending.\u001b[0m\r\n\u001b[0;90m# The requester will pull it back during the retract window.\u001b[0m\r\n"]
