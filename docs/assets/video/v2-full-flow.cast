[268.996524,"o","\u001b[H\u001b[2J\u001b[3J\u001b[1;36mPart 4: reject after Phase-3 aging\u001b[0m\r\n\r\n\u001b[0;90m# Reject becomes valid only after process+retract have both elapsed.\u001b[0m\r\n\u001b[0;90m# Waiting ~12s gives the 5s+5s windows enough room to expire.\u001b[0m\r\n"]
[268.99666,"o","\u001b[1;33mwaiting ~12s for the request to age into the rejectable phase\u001b[0m\r\n"]
[280.999405,"o","\u001b[H\u001b[2J\u001b[3J\u001b[0;90m# The request is now in Phase 3: rejectable.\u001b[0m\r\n\u001b[0;90m# Reject removes the stale request from the token state.\u001b[0m\r\n\u001b[1;32m$ moog oracle token reject -o \"$expired_ref\"\u001b[0m\r\n"]
