[261.808887,"o","\u001b[H\u001b[2J\u001b[3J\u001b[0;90m# The submitted request is now pending on the oracle token.\u001b[0m\r\n"]
[261.809218,"o","\u001b[0;90m# The outputRefId is the handle used by update, retract, and reject.\u001b[0m\r\n\u001b[1;32m$ moog token\u001b[0m\r\n"]
