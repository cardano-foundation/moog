[0.021082,"o","MOOG v2 facts-only full flow on a local devnet\r\n"]
[0.023044,"o","$ moog wallet create -w \"$wallet\"\r\n"]
[4.356944,"o","$ moog wallet info -w \"$wallet\"\r\n"]
[4.542033,"o","{\"owner\":\"ccb9a5f742de6b76597024cf8b4586b8ce1a8b6983a2f59ecf99f3d2\",\"address\":\"addr_test1vrxtnf0hgt0xkajewqjvlz69s6uvux5tdxp69av7e7vl85sxa4gst\"}\r\n"]
[4.590347,"o","funded the demo wallet in the local devnet genesis\r\n"]
[4.590371,"o","$ mpfs-devnet-server --port 38091\r\n"]
[15.691687,"o","facts devnet ready at http://127.0.0.1:38091\r\n"]
[15.69177,"o","$ moog oracle token boot --process-time-ms 5000 --retract-time-ms 5000\r\n"]
[16.132426,"o","{\"txHash\":\"2ced30da5ba2e028fdf9a6339ee9a35544577b822cc156928ff236ef65c5d90f\",\"value\":\"222d6fe78a12c5be4a208bea593a7b10ccfc01323c7d6a97a6b806591429dab0\"}\r\n"]
[16.138689,"o","token id: 222d6fe78a12c5be4a208bea593a7b10ccfc01323c7d6a97a6b806591429dab0\r\n\r\n1. Submit a config request and let the oracle apply it.\r\n"]
[16.14151,"o","$ moog oracle config set --min-test-duration 1 --max-test-duration 3\r\n"]
[16.531024,"o","{\"txHash\":\"1f2d029b88f36d315257f2bf0eabc0eea038a2b97acf682a237a1e4a1d234a97\",\"value\":\"OK\"}\r\n"]
[16.815438,"o","pending request: 1f2d029b88f36d315257f2bf0eabc0eea038a2b97acf682a237a1e4a1d234a97#0\r\n"]
[16.815519,"o","$ moog oracle token update -o 1f2d029b88f36d315257f2bf0eabc0eea038a2b97acf682a237a1e4a1d234a97#0\r\n"]
[17.233184,"o","{\"txHash\":\"37bc72b0c2325b8799acfd693e1c18843062b1a8295b7e0ac3a9b3e7a4b6d632\"}\r\n"]
[17.413015,"o","$ moog facts config\r\n"]
[17.583632,"o","[{\"id\":\"3dc03ab72db85cc1aecf6b7bd4e4d7b855e2a202ad45e6c78ad4d01812104ce9\",\"key\":{\"type\":\"config\"},\"slot\":0,\"value\":{\"agent\":\"ccb9a5f742de6b76597024cf8b4586b8ce1a8b6983a2f59ecf99f3d2\",\"protocolVersion\":0,\"testRun\":{\"maxDuration\":3,\"minDuration\":1}}}]\r\n"]
[17.586378,"o","\r\n"]
[17.586454,"o","2. Submit a second request, wait past the process and retract windows, then reject it.\r\n"]
[17.589214,"o","$ moog oracle config set --min-test-duration 1 --max-test-duration 4\r\n"]
[17.931268,"o","{\"txHash\":\"7ca28c4df0f869272b9ee4f15abdea3d9a0de62ef8a66e7c07f3401a78993b00\",\"value\":\"OK\"}\r\n"]
[18.146235,"o","pending request: 7ca28c4df0f869272b9ee4f15abdea3d9a0de62ef8a66e7c07f3401a78993b00#0\r\nwaiting 12 seconds so the request is rejectable\r\n"]
[30.148808,"o","$ moog oracle token reject -o 7ca28c4df0f869272b9ee4f15abdea3d9a0de62ef8a66e7c07f3401a78993b00#0\r\n"]
[30.534394,"o","{\"txHash\":\"79b8e2dac9cdb0919e3e21a7398a881a229a6b59ecbebbee14498320c52ad4f1\"}\r\n"]
[30.711844,"o","pending after expired reject:\r\n"]
[30.885411,"o","[]\r\n"]
[30.889579,"o","\r\n3. Submit a fresh request and prove the Phase-3 guard refuses early rejection.\r\n"]
[30.892395,"o","$ moog oracle config set --min-test-duration 1 --max-test-duration 5\r\n"]
[31.231029,"o","{\"txHash\":\"93324951fa9160d9c258a9697a112ffd6b133458656d3a6759742e59b82aeba4\",\"value\":\"OK\"}\r\n"]
[31.443451,"o","pending request: 93324951fa9160d9c258a9697a112ffd6b133458656d3a6759742e59b82aeba4#0\r\n$ moog oracle token reject -o 93324951fa9160d9c258a9697a112ffd6b133458656d3a6759742e59b82aeba4#0  # expected to fail while fresh\r\n"]
[31.633626,"o","moog: reject refused — HTTP 400: Selected request UTxO is not in the rejectable phase\r\n"]
[31.636144,"o","fresh reject refused as expected\r\ncleaning up the fresh request after it expires\r\n"]
[44.329559,"o","\r\nfull v2 flow complete\r\n"]
