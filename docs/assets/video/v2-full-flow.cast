{"version": 2, "width": 80, "height": 24, "timestamp": 1782135939, "env": {"SHELL": "/bin/bash", "TERM": "dumb"}}
[0.012283, "o", "MOOG v2 facts-only full flow on a local devnet\r\n"]
[0.014818, "o", "$ moog wallet create -w \"$wallet\"\r\n"]
[4.82249, "o", "$ moog wallet info -w \"$wallet\"\r\n"]
[4.997855, "o", "{\"owner\":\"ce7866efbd36aa920a0789a0525e21e55104db116a9863c08c76b8f7\",\"address\":\"addr_test1vr88seh0h5m24ys2q7y6q5j7y8j4zpxmz94fsc7q33mt3acekmgz2\"}\r\n"]
[5.023851, "o", "funded the demo wallet in the local devnet genesis\r\n$ mpfs-devnet-server --port 38091\r\n"]
[15.126793, "o", "facts devnet ready at http://127.0.0.1:38091\r\n$ moog oracle token boot --process-time-ms 5000 --retract-time-ms 5000\r\n"]
[15.66344, "o", "{\"txHash\":\"d6465b46e5262dcacaa3ac0df05c187f3712f2ec4b764f38475971fd6fb10886\",\"value\":\"a78531fe49aea7ed7025e4c9ad46142938ed0f3cb6147931fca989fbf7af20d7\"}\r\n"]
[15.669281, "o", "token id: a78531fe49aea7ed7025e4c9ad46142938ed0f3cb6147931fca989fbf7af20d7\r\n\r\n"]
[15.669305, "o", "1. Submit a config request and let the oracle apply it.\r\n"]
[15.672377, "o", "$ moog oracle config set --min-test-duration 1 --max-test-duration 3\r\n"]
[16.163828, "o", "{\"txHash\":\"ec923eee1f2ad18364ae0fb9ab0155f47e13cc2c1f9bed4a501d066fefaaad6b\",\"value\":\"OK\"}\r\n"]
[16.410749, "o", "pending request: ec923eee1f2ad18364ae0fb9ab0155f47e13cc2c1f9bed4a501d066fefaaad6b#0\r\n"]
[16.410846, "o", "$ moog oracle token update -o ec923eee1f2ad18364ae0fb9ab0155f47e13cc2c1f9bed4a501d066fefaaad6b#0\r\n"]
[16.862083, "o", "{\"txHash\":\"bb3303d6e7495a13ebabec9ae9fc0c8cf185800e5dd5d0e70ab0de96edbcfe0e\"}\r\n"]
[17.092251, "o", "$ moog facts config\r\n"]
[17.288711, "o", "[{\"id\":\"3dc03ab72db85cc1aecf6b7bd4e4d7b855e2a202ad45e6c78ad4d01812104ce9\",\"key\":{\"type\":\"config\"},\"slot\":0,\"value\":{\"agent\":\"ce7866efbd36aa920a0789a0525e21e55104db116a9863c08c76b8f7\",\"protocolVersion\":0,\"testRun\":{\"maxDuration\":3,\"minDuration\":1}}}]\r\n"]
[17.290444, "o", "\r\n"]
[17.290487, "o", "2. Submit a second request, wait past the process and retract windows, then reject it.\r\n"]
[17.292941, "o", "$ moog oracle config set --min-test-duration 1 --max-test-duration 4\r\n"]
[17.760661, "o", "{\"txHash\":\"818149c20519e510a941f7da6d2bb01636bcc2375a981a1f0bc8334dc37f0a7a\",\"value\":\"OK\"}\r\n"]
[19.17398, "o", "pending request: 818149c20519e510a941f7da6d2bb01636bcc2375a981a1f0bc8334dc37f0a7a#0\r\nwaiting 12 seconds so the request is rejectable\r\n"]
[31.176543, "o", "$ moog oracle token reject -o 818149c20519e510a941f7da6d2bb01636bcc2375a981a1f0bc8334dc37f0a7a#0\r\n"]
[31.763694, "o", "{\"txHash\":\"ae547e552d366b87572d1044ea3d7e4472482a51a1d115f429c29995f046835e\"}\r\n"]
[32.038099, "o", "pending after expired reject:\r\n"]
[32.226357, "o", "[]\r\n"]
[32.229374, "o", "\r\n3. Submit a fresh request and prove the Phase-3 guard refuses early rejection.\r\n"]
[32.232119, "o", "$ moog oracle config set --min-test-duration 1 --max-test-duration 5\r\n"]
[32.560949, "o", "{\"txHash\":\"bcccededeab7d924527dc34fd5eb74be975b62491d56289b111f3e59e4b835fe\",\"value\":\"OK\"}\r\n"]
[34.073673, "o", "pending request: bcccededeab7d924527dc34fd5eb74be975b62491d56289b111f3e59e4b835fe#0\r\n$ moog oracle token reject -o bcccededeab7d924527dc34fd5eb74be975b62491d56289b111f3e59e4b835fe#0  # expected to fail while fresh\r\n"]
[34.322823, "o", "moog: reject refused - Selected request UTxO is not in the rejectable phase\r\n"]
[34.325207, "o", "fresh reject refused as expected\r\ncleaning up the fresh request after it expires\r\n"]
[46.973147, "o", "\r\nfull v2 flow complete\r\n"]
