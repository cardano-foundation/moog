[120.12787,"o","\u001b[0;90m# The validator reads the same moog.vkey from paolino/paolino.\u001b[0m\r\n\u001b[0;90m# The request is submitted first; facts change only after oracle update.\u001b[0m\r\n\u001b[1;32m$ moog requester register-user -p github -u paolino -v <profile-vkey>\u001b[0m\r\n"]
