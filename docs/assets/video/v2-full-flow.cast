[0.03842,"o","\u001b[H\u001b[2J\u001b[3J\u001b[1;36mMOOG v2 full feature tour\u001b[0m\r\n\r\n\u001b[0;90m# A local devnet keeps the recording deterministic.\u001b[0m\r\n\u001b[0;90m# The tour covers wallets, requests, facts, and request lifecycle.\u001b[0m\r\n"]
[4.040427,"o","\u001b[H\u001b[2J\u001b[3J\u001b[1;36mPart 1: Wallet & key management\u001b[0m\r\n\r\n\u001b[0;90m# Create, inspect, encrypt, decrypt, and refuse a wrong passphrase.\u001b[0m\r\n"]
[11.040427,"o","\u001b[H\u001b[2J\u001b[3J\u001b[1;36mPart 1: wallet create\u001b[0m\r\n\r\n\u001b[0;90m# Create a disposable wallet for the tour.\u001b[0m\r\n\u001b[0;90m# This first part stays offline: key material only, no devnet.\u001b[0m\r\n\u001b[1;32m$ moog wallet create -w \"$wallet\"\u001b[0m\r\n"]
[11.227477,"o","\u001b[1;33mdemo wallet created\u001b[0m\r\n"]
[18.227477,"o","\u001b[H\u001b[2J\u001b[3J\u001b[1;36mPart 1: wallet info\u001b[0m\r\n\r\n\u001b[0;90m# The owner public key hash identifies the wallet on-chain.\u001b[0m\r\n\u001b[0;90m# The address is funded in genesis before the local devnet starts.\u001b[0m\r\n"]
[18.22761,"o","\u001b[1;32m$ moog wallet info -w \"$wallet\"\u001b[0m\r\n"]
[18.427364,"o","{\r\n  \"owner\": \"405e36db9f7e5ae5704377b40cadc1bd45797b4d08007e24274b6233\",\r\n  \"address\": \"addr_test1vpq9udkmnal94etsgdmmgr9dcx7527tmf5yqql3yya9kyvcptjcf9\"\r\n}\r\n"]
[25.427364,"o","\u001b[H\u001b[2J\u001b[3J\u001b[1;36mPart 1: encrypt the wallet\u001b[0m\r\n\r\n\u001b[0;90m# The encryptedMnemonics field is the authenticated v2 vault.\u001b[0m\r\n\u001b[0;90m# The cast shows a compact preview rather than the whole ciphertext.\u001b[0m\r\n\u001b[1;32m$ moog wallet encrypt -w \"$wallet\" --ask-wallet-passphrase \"$encrypted_wallet\"\u001b[0m\r\n"]
[25.662273,"o","{\r\n  \"encryptedMnemonics\": \"0ad91e31889750ff567339e8060da01ef50688324f571c230642a2a6...\",\r\n  \"ciphertextBytes\": 122\r\n}\r\n"]
[25.662417,"o","\u001b[1;33mencryptedMnemonics carries the authenticated age/scrypt vault\u001b[0m\r\n"]
[32.662417,"o","\u001b[H\u001b[2J\u001b[3J\u001b[1;36mPart 1: decrypt with the right passphrase\u001b[0m\r\n\r\n\u001b[0;90m# Decrypt with the correct passphrase.\u001b[0m\r\n\u001b[0;90m# Then compare wallet info to prove the owner hash round-trips.\u001b[0m\r\n\u001b[1;32m$ moog wallet decrypt -w \"$encrypted_wallet\" --ask-wallet-passphrase \"$recovered_wallet\"\u001b[0m\r\n"]
[33.135596,"o","{\r\n  \"owner\": \"405e36db9f7e5ae5704377b40cadc1bd45797b4d08007e24274b6233\",\r\n  \"address\": \"addr_test1vpq9udkmnal94etsgdmmgr9dcx7527tmf5yqql3yya9kyvcptjcf9\"\r\n}\r\n"]
[33.141243,"o","\u001b[1;33mround-trip owner matches:\u001b[0m\r\n"]
[33.143687,"o","\u001b[1;33m405e36db9f7e5ae5704377b40cadc1bd45797b4d08007e24274b6233\u001b[0m\r\n"]
[40.143687,"o","\u001b[H\u001b[2J\u001b[3J\u001b[1;36mPart 1: wrong passphrase refused\u001b[0m\r\n\r\n\u001b[0;90m# Now try the wrong passphrase.\u001b[0m\r\n\u001b[0;90m# The expected result is a clean refusal and no recovered wallet file.\u001b[0m\r\n"]
[40.143727,"o","\u001b[1;32m$ moog wallet decrypt -w \"$encrypted_wallet\" --ask-wallet-passphrase \"$bad_wallet\"\u001b[0m\r\n"]
[40.377071,"o","\u001b[0;31mexpected decrypt refusal:\u001b[0m\r\n\u001b[0;31mDecryption failed: invalid UTF8 decrypted\u001b[0m\r\n\u001b[1;33mwrong passphrase refused cleanly\u001b[0m\r\n"]
[44.414656,"o","\u001b[1;33mfunded the demo wallet in the local devnet genesis\u001b[0m\r\n"]
[51.414656,"o","\u001b[H\u001b[2J\u001b[3J\u001b[1;36mPart 2: Boot the oracle token\u001b[0m\r\n\r\n\u001b[0;90m# Start the local facts devnet and create the v2 lifecycle token.\u001b[0m\r\n"]
[58.414656,"o","\u001b[H\u001b[2J\u001b[3J\u001b[1;36mSetup: start the facts devnet\u001b[0m\r\n\r\n"]
[58.414697,"o","\u001b[0;90m# Start a private MPFS facts devnet for the recording.\u001b[0m\r\n\u001b[0;90m# The visible moog commands talk only to this local server.\u001b[0m\r\n"]
[58.414796,"o","\u001b[1;32m$ mpfs-devnet-server --port 38091\u001b[0m\r\n"]
[69.521545,"o","\u001b[1;33mfacts devnet ready at http://127.0.0.1:38091\u001b[0m\r\n"]
[76.521545,"o","\u001b[H\u001b[2J\u001b[3J\u001b[1;36mPart 2: boot the oracle token\u001b[0m\r\n\r\n\u001b[0;90m# Boot creates the local oracle token.\u001b[0m\r\n\u001b[0;90m# process: the oracle may apply a request.\u001b[0m\r\n\u001b[0;90m# retract: the requester may pull the request back.\u001b[0m\r\n\u001b[0;90m# rejectable / Phase-3: the oracle may remove stale requests.\u001b[0m\r\n\u001b[1;32m$ moog oracle token boot --process-time-ms 5000 --retract-time-ms 5000 --tip 1000000\u001b[0m\r\n"]
[76.931038,"o","{\r\n  \"txHash\": \"6c164c29e6ee34391e3b46407f6bf6a9ab8af4c6ed00cdb1200592dee5ee42c7\",\r\n  \"value\": \"be1c636539e0027b8c69c9ffc5e44b2798b7319e7e7583d38f5d25ad05736a39\"\r\n}\r\n"]
[76.939596,"o","\u001b[1;33mtoken id:\u001b[0m\r\n\u001b[1;33mbe1c636539e0027b8c69c9ffc5e44b2798b7319e7e7583d38f5d25ad05736a39\u001b[0m\r\n"]
[83.939596,"o","\u001b[H\u001b[2J\u001b[3J\u001b[1;36mPart 3: Populate the facts DB via requests\u001b[0m\r\n\r\n\u001b[0;90m# Submit each local request type, apply it, then read its facts table.\u001b[0m\r\n"]
[90.939596,"o","\u001b[H\u001b[2J\u001b[3J\u001b[1;36mPart 3: request oracle config set\u001b[0m\r\n\r\n"]
[90.940044,"o","\u001b[0;90m# The oracle config is itself updated through a request.\u001b[0m\r\n\u001b[0;90m# Applying it writes policy and the active agent key into facts.\u001b[0m\r\n\u001b[1;32m$ moog oracle config set --min-test-duration 1 --max-test-duration 3\u001b[0m\r\n"]
[91.227485,"o","{\r\n  \"txHash\": \"592d06fca40e2221d4706a32f660519082816e185d77bb61572d31a1d8c20f33\",\r\n  \"value\": \"OK\"\r\n}\r\n"]
[98.227485,"o","\u001b[H\u001b[2J\u001b[3J\u001b[0;90m# The submitted request is now pending on the oracle token.\u001b[0m\r\n\u001b[0;90m# The outputRefId is the handle used by update, retract, and reject.\u001b[0m\r\n"]
[98.227516,"o","\u001b[1;32m$ moog token\u001b[0m\r\n"]
[98.403856,"o","{\r\n  \"pending\": [\r\n    \"592d06fca40e2221d4706a32f660519082816e185d77bb61572d31a1d8c20f33#0\"\r\n  ],\r\n  \"requestCount\": 1\r\n}\r\n"]
[105.403856,"o","\u001b[H\u001b[2J\u001b[3J\u001b[0;90m# The request is still processable.\u001b[0m\r\n"]
[105.404227,"o","\u001b[0;90m# The oracle applies it before it ages into the retract window.\u001b[0m\r\n\u001b[1;32m$ moog oracle token update -o \"$request_ref\"\u001b[0m\r\n"]
[105.941374,"o","{\r\n  \"txHash\": \"37f6a0763c818c9bd70be44dc82ed3ca82a92d64fbca8673d0d731d359f58a6e\"\r\n}\r\n"]
